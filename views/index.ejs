<%- include('./partials/header', { title: 'Home' }) %>

<style>
/* ── Hero ── */
.hero {
  min-height: calc(100vh - 64px);
  background: linear-gradient(155deg, var(--green-900) 0%, var(--green-800) 50%, var(--green-700) 100%);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 4rem 2rem;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 680px;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.15);
  color: var(--green-200);
  padding: 6px 16px;
  border-radius: 100px;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 6rem);
  color: white;
  letter-spacing: 4px;
  line-height: 1.05;
  margin-bottom: 1.5rem;
}

.hero h1 span { color: var(--gold); }

.hero p {
  font-size: 1.15rem;
  color: var(--green-200);
  line-height: 1.7;
  margin-bottom: 2.5rem;
  max-width: 520px;
}

.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

.hero-graphic {
  position: absolute;
  right: -60px;
  top: 50%;
  transform: translateY(-50%);
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(34,133,47,0.35) 0%, transparent 70%);
  animation: pulse-green 4s ease infinite;
}

.hero-stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.15);
}

.hero-stat-num {
  font-family: var(--font-display);
  font-size: 2.2rem;
  color: var(--gold);
  letter-spacing: 2px;
}

.hero-stat-label {
  font-size: 0.78rem;
  color: var(--green-300);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 500;
}

/* ── Features Section ── */
.features {
  padding: 5rem 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.section-header { text-align: center; margin-bottom: 3.5rem; }
.section-label {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--green-500);
  margin-bottom: 0.75rem;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

.feature-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 2rem;
  border: 1px solid var(--gray-100);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.feature-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--green-200);
}

.feature-icon {
  width: 52px;
  height: 52px;
  background: var(--green-100);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  margin-bottom: 1.25rem;
}

.feature-card h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
.feature-card p  { font-size: 0.9rem; color: var(--gray-600); line-height: 1.6; }

/* ── Role Cards ── */
.roles { background: var(--green-900); padding: 5rem 2rem; }
.roles-inner { max-width: 1200px; margin: 0 auto; }
.roles h2 { color: white; text-align: center; margin-bottom: 0.75rem; }
.roles .section-label { color: var(--green-300); }
.roles p.sub { text-align: center; color: var(--green-300); margin-bottom: 3rem; }

.role-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
}

.role-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius-lg);
  padding: 2.5rem 2rem;
  text-align: center;
  transition: var(--transition);
  cursor: pointer;
}

.role-card:hover {
  background: rgba(255,255,255,0.1);
  border-color: var(--green-400);
  transform: translateY(-4px);
}

.role-emoji { font-size: 2.5rem; margin-bottom: 1rem; }
.role-card h3 { color: white; margin-bottom: 0.5rem; font-size: 1.2rem; }
.role-card p  { color: var(--green-300); font-size: 0.875rem; line-height: 1.6; margin-bottom: 1.5rem; }
</style>

<!-- ── Hero ── -->
<section class="hero">
  <div class="hero-content animate-fade-up">
    <div class="hero-eyebrow">
      <span>🏆</span> CSH Athletic Department
    </div>
    <h1>ATHLETIC<br><span>TRACK</span></h1>
    <p>Bridging the gap between classroom performance and athletic excellence. Real-time academic updates for coaches, teachers, and student-athletes.</p>
    <div class="hero-cta">
      <a href="/login" class="btn btn-gold btn-lg">Get Started →</a>
      <a href="#features" class="btn btn-outline btn-lg" style="color:var(--green-200);border-color:rgba(255,255,255,0.3);">Learn More</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="hero-stat-num">3</div>
        <div class="hero-stat-label">User Roles</div>
      </div>
      <div>
        <div class="hero-stat-num">100%</div>
        <div class="hero-stat-label">Secure</div>
      </div>
      <div>
        <div class="hero-stat-num">Live</div>
        <div class="hero-stat-label">Updates</div>
      </div>
    </div>
  </div>
  <div class="hero-graphic"></div>
</section>

<!-- ── Features ── -->
<section class="features" id="features">
  <div class="section-header animate-fade-up">
    <div class="section-label">Why AthleticTrack</div>
    <h2>Everything you need, all in one place</h2>
  </div>

  <div class="features-grid">
    <div class="feature-card animate-fade-up animate-delay-1">
      <div class="feature-icon">📊</div>
      <h3>Real-Time Reports</h3>
      <p>Teachers submit grade, attendance, and behavior updates instantly. No more delays or missed communications.</p>
    </div>
    <div class="feature-card animate-fade-up animate-delay-2">
      <div class="feature-icon">🏈</div>
      <h3>Coach Dashboard</h3>
      <p>Coaches get a clear overview of every player's academic standing — filtered by team, sport, or grade level.</p>
    </div>
    <div class="feature-card animate-fade-up animate-delay-3">
      <div class="feature-icon">🎓</div>
      <h3>Student Portal</h3>
      <p>Student-athletes can view their own progress reports, stay informed, and take ownership of their academics.</p>
    </div>
    <div class="feature-card animate-fade-up animate-delay-4">
      <div class="feature-icon">🔍</div>
      <h3>Smart Search & Filter</h3>
      <p>Instantly search by name, filter by sport or team. Find the information you need in seconds.</p>
    </div>
    <div class="feature-card animate-fade-up animate-delay-1">
      <div class="feature-icon">🔐</div>
      <h3>Secure Role-Based Login</h3>
      <p>Separate, secure login for teachers, coaches, and students. Everyone sees only what they need to.</p>
    </div>
    <div class="feature-card animate-fade-up animate-delay-2">
      <div class="feature-icon">📈</div>
      <h3>Progress Tracking</h3>
      <p>Visual grade trend charts help identify students who need extra support before it becomes a bigger issue.</p>
    </div>
  </div>
</section>

<!-- ── Role Cards ── -->
<section class="roles">
  <div class="roles-inner">
    <div class="section-label" style="display:block;text-align:center;margin-bottom:0.5rem;">Who It's For</div>
    <h2>Built for your role</h2>
    <p class="sub">Different views, one shared goal — student-athlete success.</p>

    <div class="role-cards">
      <a href="/login" class="role-card" style="text-decoration:none;">
        <div class="role-emoji">📚</div>
        <h3>Teachers</h3>
        <p>Submit grade updates, attendance records, and behavior notes in seconds. Reach every coach at once.</p>
        <span class="btn btn-outline btn-sm" style="color:var(--green-300);border-color:rgba(255,255,255,0.2);">Teacher Login</span>
      </a>
      <a href="/login" class="role-card" style="text-decoration:none;">
        <div class="role-emoji">🏆</div>
        <h3>Coaches</h3>
        <p>Monitor your entire team's academic progress. Get ahead of eligibility issues before they arise.</p>
        <span class="btn btn-gold btn-sm">Coach Login</span>
      </a>
      <a href="/login" class="role-card" style="text-decoration:none;">
        <div class="role-emoji">⚡</div>
        <h3>Student-Athletes</h3>
        <p>Check your own reports. Stay informed, stay eligible, and stay on top of your game — on and off the field.</p>
        <span class="btn btn-outline btn-sm" style="color:var(--green-300);border-color:rgba(255,255,255,0.2);">Student Login</span>
      </a>
    </div>
  </div>
</section>

<%- include('./partials/footer') %>