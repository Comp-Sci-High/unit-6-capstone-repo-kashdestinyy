<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coach Dashboard</title>

    <link rel="stylesheet" href="/css/dashboard.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="sidebar">

        <h2>GamePlan</h2>

        <ul>
            <li>🏠 Dashboard</li>
            <li>🏆 Teams</li>
            <li>📚 Reports</li>
            <li>📈 Progress</li>
            <li>⚙️ Settings</li>
        </ul>

    </div>

    <div class="main-content">

        <div class="top-section">

            <h1>Coach Dashboard</h1>

            <input type="text" placeholder="Search athletes...">

        </div>

        <div class="alert-box">
            ⚠️ 3 Student-Athletes Need Academic Attention
        </div>

        <div class="cards">

            <div class="student-card">
                <h2>Jordan Smith</h2>

                <p>Basketball</p>

                <div class="grade good">
                    GPA: 92%
                </div>

                <p>Attendance Excellent</p>
            </div>

            <div class="student-card warning-card">
                <h2>Maria Lopez</h2>

                <p>Soccer</p>

                <div class="grade warning">
                    GPA: 71%
                </div>

                <p>2 Missing Assignments</p>
            </div>

            <div class="student-card danger-card">
                <h2>Jayden Carter</h2>

                <p>Track & Field</p>

                <div class="grade danger">
                    GPA: 64%
                </div>

                <p>Attendance Concern</p>
            </div>

        </div>

    </div>

</body>
</html>