<%- include('./partials/header', { title: 'My Progress' }) %>

<style>
.student-hero {
  background: linear-gradient(135deg, var(--green-900) 0%, var(--green-700) 100%);
  padding: 2.5rem 2rem;
  position: relative;
  overflow: hidden;
}

.student-hero::before {
  content: '';
  position: absolute;
  right: -100px; top: -100px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(34,133,47,0.15);
}

.student-hero-content {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.student-avatar-big {
  width: 80px; height: 80px;
  border-radius: 50%;
  background: var(--green-500);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  color: white;
  font-weight: 700;
  border: 3px solid rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.student-hero h1 { color: white; font-size: 2rem; margin-bottom: 0.25rem; }
.student-hero p  { color: var(--green-200); font-size: 0.9rem; }

.gpa-badge {
  background: rgba(255,255,255,0.1);
  border: 2px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-md);
  padding: 1.25rem 2rem;
  text-align: center;
  flex-shrink: 0;
}

.gpa-value {
  font-family: var(--font-display);
  font-size: 3rem;
  color: var(--gold);
  letter-spacing: 2px;
  line-height: 1;
}

.gpa-label {
  font-size: 0.72rem;
  color: var(--green-300);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  font-weight: 600;
  margin-top: 4px;
}

.report-card {
  background: white;
  border-radius: var(--radius-md);
  border: 1px solid var(--gray-100);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: var(--transition);
}

.report-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

.report-card-header {
  padding: 1rem 1.25rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--gray-100);
}

.report-subject {
  font-weight: 700;
  font-size: 1rem;
  color: var(--green-900);
}

.report-teacher {
  font-size: 0.78rem;
  color: var(--gray-400);
  margin-top: 2px;
}

.report-grade-display {
  font-family: var(--font-display);
  font-size: 2.5rem;
  letter-spacing: 2px;
  line-height: 1;
}

.report-card-body {
  padding: 1rem 1.25rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.report-field label {
  display: block;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--gray-400);
  margin-bottom: 2px;
}

.report-field span {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--gray-800);
}

.report-comments {
  padding: 0.75rem 1.25rem;
  background: var(--green-50);
  font-size: 0.85rem;
  color: var(--gray-600);
  border-top: 1px solid var(--gray-100);
  font-style: italic;
  line-height: 1.6;
}

.reports-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.25rem;
}

.chart-card {
  background: white;
  border-radius: var(--radius-md);
  border: 1px solid var(--gray-100);
  box-shadow: var(--shadow-sm);
  padding: 1.5rem;
}

.chart-card h3 { margin-bottom: 1.25rem; }
</style>

<!-- Student Hero -->
<div class="student-hero">
  <div class="student-hero-content">
    <div class="flex items-center gap-2">
      <div class="student-avatar-big">S</div>
      <div>
        <h1>My Progress Report</h1>
        <p>Student ID: <span class="font-mono"><%= studentId %></span></p>
        <p style="margin-top:4px">Cold Spring Harbor School District — Athletic Division</p>
      </div>
    </div>
    <%
      const gradePoints = { A: 4.0, B: 3.0, C: 2.0, D: 1.0, F: 0.0 };
      let gpa = 'N/A';
      if (reports.length > 0) {
        const sum = reports.reduce((acc, r) => {
          const g = r.grade?.charAt(0);
          return acc + (gradePoints[g] || 0);
        }, 0);
        gpa = (sum / reports.length).toFixed(2);
      }
    %>
    <div class="gpa-badge">
      <div class="gpa-value"><%= gpa %></div>
      <div class="gpa-label">Current GPA</div>
    </div>
  </div>
</div>

<div class="page-content">

  <!-- Stats -->
  <div class="stats-grid animate-fade-up">
    <div class="stat-card">
      <div class="stat-value"><%= reports.length %></div>
      <div class="stat-label">Reports Received</div>
    </div>
    <div class="stat-card">
      <%
        const absences = reports.filter(r => r.attendance === 'Absent').length;
      %>
      <div class="stat-value" style="color:<%= absences > 3 ? '#c00' : 'var(--green-600)' %>"><%= absences %></div>
      <div class="stat-label">Absences</div>
    </div>
    <div class="stat-card">
      <%
        const passing = reports.filter(r => r.grade && !['D','F'].includes(r.grade.charAt(0))).length;
      %>
      <div class="stat-value"><%= passing %></div>
      <div class="stat-label">Passing Classes</div>
    </div>
    <div class="stat-card">
      <%
        const flagged = reports.filter(r => r.grade && ['D','F'].includes(r.grade.charAt(0))).length;
      %>
      <div class="stat-value" style="color:<%= flagged > 0 ? '#c00' : 'var(--green-600)' %>"><%= flagged %></div>
      <div class="stat-label">Needs Attention</div>
    </div>
  </div>

  <% if (reports.length > 2) { %>
  <!-- Grade Trend Chart -->
  <div class="chart-card animate-fade-up animate-delay-1 mt-3">
    <h3>📈 Grade Trend</h3>
    <canvas id="gradeChart" data-student="<%= studentId %>" width="800" height="220" style="width:100%;height:220px"></canvas>
  </div>
  <% } %>

  <!-- Report Cards Grid -->
  <h3 class="animate-fade-up animate-delay-2 mt-4 mb-2" style="color:var(--green-900)">All Reports</h3>

  <% if (reports.length === 0) { %>
    <div class="card" style="text-align:center;padding:4rem;color:var(--gray-400)">
      <p style="font-size:2rem;margin-bottom:1rem">📋</p>
      <p>No reports have been submitted yet. Check back after your teachers submit updates.</p>
    </div>
  <% } else { %>
    <div class="reports-grid animate-fade-up animate-delay-3">
      <% reports.forEach(r => {
        const gradeChar = r.grade?.charAt(0);
      %>
      <div class="report-card">
        <div class="report-card-header">
          <div>
            <div class="report-subject"><%= r.subject %></div>
            <div class="report-teacher">Submitted by <%= r.teacherName %></div>
          </div>
          <div class="report-grade-display grade-<%= gradeChar %>"><%= r.grade %></div>
        </div>
        <div class="report-card-body">
          <div class="report-field">
            <label>Attendance</label>
            <span class="badge <%=
              r.attendance === 'Present' ? 'badge-green' :
              r.attendance === 'Tardy'   ? 'badge-gold'  : 'badge-red'
            %>"><%= r.attendance %></span>
          </div>
          <div class="report-field">
            <label>Behavior</label>
            <span class="badge <%=
              r.behavior === 'Excellent' || r.behavior === 'Good' ? 'badge-green' :
              r.behavior === 'Needs Improvement'                  ? 'badge-gold'  : 'badge-red'
            %>"><%= r.behavior %></span>
          </div>
          <div class="report-field">
            <label>Sport</label>
            <span><%= r.sport || '—' %></span>
          </div>
          <div class="report-field">
            <label>Date</label>
            <span class="font-mono text-sm"><%= new Date(r.createdAt).toLocaleDateString() %></span>
          </div>
        </div>
        <% if (r.comments) { %>
          <div class="report-comments">"<%= r.comments %>"</div>
        <% } %>
      </div>
      <% }) %>
    </div>
  <% } %>

</div>

<%- include('./partials/footer') %>